<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clouds 2025</title>

  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      min-height: 100%;
      background: #000;
      color: #fff;
      font-family: Arial, sans-serif;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .page {
      width: 100%;
      max-width: 1400px;
      padding: 24px;
      box-sizing: border-box;
      text-align: center;
    }

    h1 {
      margin: 0 0 8px 0;
      font-size: 1.8rem;
      font-weight: 400;
      letter-spacing: 0.02em;
    }

    h2 {
      margin: 0 0 24px 0;
      font-size: 1rem;
      font-weight: 400;
      color: #ccc;
      text-transform: lowercase;
      letter-spacing: 0.04em;
    }

    .video-wrap {
      position: relative;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      aspect-ratio: 16 / 9;
      background: #000;
    }

    .video-wrap iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }
  </style>
</head>

<body>
  <div class="page">
    <h1>Clouds 2025</h1>
    <h2>matte background</h2>

    <div class="video-wrap">
      <iframe
        src="https://www.youtube-nocookie.com/embed/-yywDae5He0?controls=1&rel=0&fs=1"
        title="Clouds 2025"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
        allowfullscreen>
      </iframe>
    </div>
  </div>
</body>
</html>
